# Copy to .env and adjust. Used by docker compose and any local API server.
POSTGRES_USER=stocks
POSTGRES_PASSWORD=stocks_dev_change_me
POSTGRES_DB=stocks
POSTGRES_PORT=5432

# For Node/pg libraries (use the same values as above)
DATABASE_URL=postgresql://stocks:stocks_dev_change_me@localhost:5432/stocks

# Portfolio API (server/portfolio-api.mjs). Vite proxies /api to this port in dev.
PORTFOLIO_API_PORT=3002